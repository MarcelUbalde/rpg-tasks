DATABASE_URL=postgres://rpg:rpg_dev_password@localhost:5433/rpg_tasks
NODE_ENV=development
PORT=3000

# Jira Webhook (POST /api/jira/webhook)
# Los valores de customfield_* son especificos de la instancia Vibia (confirmados en DV-6064).
JIRA_WEBHOOK_SECRET=change-me
JIRA_DONE_STATUS_NAME=Finalizada
JIRA_SP_FIELD=customfield_10009
JIRA_SEVERITY_FIELD=
JIRA_DEVELOPERS_FIELD=customfield_10819
JIRA_QA_FIELD=customfield_10818
JIRA_BUG_ISSUE_TYPES=Error,Defecto
JIRA_TASK_ISSUE_TYPES=Technical Story,Historia,Tarea

# Mapeo Jira accountId -> RPG userId (ejemplo con usuarios de Vibia dev: Marcel, Alejandro, Luis Enrique)
USER_MAP_JSON={"712020:eb206518-3f3b-4297-87a8-d2ab988baf23":"u1","712020:12a1eecc-1308-4946-b4e0-b2a7e1c905a0":"u2","712020:8a73806b-493b-49c8-a003-5a9af5d4c4c2":"u3"}
